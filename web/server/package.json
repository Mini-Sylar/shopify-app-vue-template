{
  "name": "server",
  "version": "3.5.0",
  "private": true,
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "debug": "node --inspect-brk --enable-source-maps --import @swc-node/register/esm-register src/index.ts",
    "dev": "cross-env NODE_ENV=development nodemon --ext ts,js --exec \"node --enable-source-maps --import @swc-node/register/esm-register\" src/index.ts --ignore ../client",
    "build": "swc ./src -d dist",
    "serve": "cross-env NODE_ENV=production node --enable-source-maps dist/index.js",
    "start": "npm run typecheck && npm run build && npm run serve",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@shopify/shopify-app-express": "^7.0.1",
    "@minisylar/shopify-app-session-storage-better-sqlite": "^1.1.3",
    "better-sqlite3": "^12.11.1",
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "serve-static": "^2.2.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "nodemon": "^3.1.14",
    "typescript": "~6.0.3",
    "@types/better-sqlite3": "^7.6.13"
  }
}
