{
  "name": "shopify-app-vue-template",
  "version": "3.5.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "workspaces": [
    "web/client",
    "web/server"
  ],
  "scripts": {
    "shopify": "shopify",
    "build": "shopify app build",
    "dev": "shopify app dev",
    "dev:local": "shopify app dev --use-localhost",
    "dev:reset": "shopify app dev --reset",
    "dev:webhook": "shopify app webhook trigger",
    "info": "shopify app info",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "show:env": "shopify app env show",
    "lint": "npm-run-all2 --parallel lint:*",
    "lint:server": "eslint \"web/server/src/**/*.js\" --fix --ignore-pattern .gitignore",
    "lint:client": "eslint \"web/client/src/**/*.{js,vue}\" --fix --ignore-pattern .gitignore",
    "format": "npm-run-all2 --parallel format:*",
    "format:server": "prettier --write web/server/src/",
    "format:client": "prettier --write web/client/src/",
    "client:install": "npm install --workspace web/client",
    "client:uninstall": "npm uninstall --workspace web/client",
    "server:install": "npm install --workspace web/server",
    "server:uninstall": "npm uninstall --workspace web/server",
    "version:patch": "npm version patch --workspaces --include-workspace-root --no-git-tag-version && npm install --package-lock-only",
    "version:minor": "npm version minor --workspaces --include-workspace-root --no-git-tag-version && npm install --package-lock-only",
    "version:major": "npm version major --workspaces --include-workspace-root --no-git-tag-version && npm install --package-lock-only"
  },
  "optionalDependencies": {
    "@shopify/cli": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4"
  }
}
